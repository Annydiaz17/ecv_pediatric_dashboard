# Configuración del Dashboard ECV Pediátrico
# Copiar este archivo como .env y ajustar los valores

# Modo de ejecución: development | production
DASH_ENV=development

# Debug mode (solo en development)
DASH_DEBUG=True

# Host y Puerto
DASH_HOST=0.0.0.0
DASH_PORT=8050

# Ruta al modelo entrenado
MODEL_PATH=models/modelo_final_GradientBoosting.joblib

# Ruta a los datos
DATA_PATH=data/dataset_ecv_pediatrico.csv

# Ruta para logs de auditoría
AUDIT_LOG_PATH=data/audit_log.csv

# Número de workers de Gunicorn (recomendado: 2 * CPU cores + 1)
GUNICORN_WORKERS=4
GUNICORN_BIND=0.0.0.0:8050
GUNICORN_TIMEOUT=120
